#!/usr/bin/env bash
# Pre-push: refuse the push if any gate check fails. Same gate as CI — both call
# `poe check`, which lives in pyproject.toml as the single source of truth.
set -euo pipefail

command -v uv >/dev/null 2>&1 || {
  echo "[pre-push] ERROR: 'uv' not found. Install it: https://docs.astral.sh/uv/"
  exit 1
}

uv run poe check
