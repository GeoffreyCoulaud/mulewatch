# Secrets et variables d'environnement du déploiement.
# Copier en `.env` (gitignoré) et renseigner. Les flags applicatifs
# (download.enabled, port_sync.enabled) vivent dans
# config/crawler/crawler.yml, PAS ici.

# --- Toutes stacks ---
# mot de passe EC (crawler <-> amuled), >= 12 caractères
AMULE_EC_PASSWORD=change-me
IMAGE_TAG=latest                       # tag des images GHCR

# --- Stack gluetun (VPN) ---
# clé privée WireGuard (espace client du fournisseur)
WIREGUARD_PRIVATE_KEY=change-me
VPN_SERVICE_PROVIDER=protonvpn
# ex: Switzerland,France (noms anglais)
SERVER_COUNTRIES=
# on => High-ID (avec port_sync.enabled: true dans crawler.yml)
VPN_PORT_FORWARDING=off

# --- Stack par défaut (sans VPN), High-ID optionnel ---
# port redirigé sur la box (NAT) pour le High-ID
LISTEN_PORT=4662

# --- Monitoring (prometheus + grafana, toujours actifs) ---
GRAFANA_PWD=change-me
GRAFANA_PORT=3000
