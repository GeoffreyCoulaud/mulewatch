    {
      "vulnerability": { "name": "CVE-2025-60876" },
      "timestamp": "2026-07-08T00:00:00Z",
      "products": [
        {
          "@id": "pkg:oci/mulewatch-verifier",
          "subcomponents": [
            { "@id": "pkg:apk/alpine/busybox" },
            { "@id": "pkg:apk/alpine/busybox-binsh" },
            { "@id": "pkg:apk/alpine/ssl_client" }
          ]
        }
      ],
      "status": "not_affected",
      "justification": "vulnerable_code_not_in_execute_path",
      "impact_statement": "The busybox wget applet is present but the application never invokes it. An exploitable request-target injection requires a wget call built from untrusted input, which our source never makes."
    },
    {
      "vulnerability": { "name": "CVE-2016-1405" },
      "timestamp": "2026-07-08T00:00:00Z",
      "products": [
        {
          "@id": "pkg:oci/mulewatch-verifier",
          "subcomponents": [
            { "@id": "pkg:apk/alpine/clamav" },
            { "@id": "pkg:apk/alpine/clamav-clamdscan" },
            { "@id": "pkg:apk/alpine/clamav-daemon" },
            { "@id": "pkg:apk/alpine/clamav-libs" },
            { "@id": "pkg:apk/alpine/clamav-scanner" },
            { "@id": "pkg:apk/alpine/freshclam" }
          ]
        }
      ],
      "status": "not_affected",
      "justification": "vulnerable_code_not_present",
      "impact_statement": "The 2016 libclamav OLE2 defect was fixed upstream in ClamAV 0.99 (Debian fixed 0.99+dfsg-1). This image ships ClamAV >= 0.99, well past the fix. The NVD record uses an unbounded clamav:clamav:* CPE that over-matches modern releases."
    },
    {
      "vulnerability": { "name": "CVE-2026-58055" },
      "timestamp": "2026-07-08T00:00:00Z",
      "products": [
        {
          "@id": "pkg:oci/mulewatch-verifier",
          "subcomponents": [
            { "@id": "pkg:apk/alpine/nghttp2-libs" }
          ]
        }
      ],
      "status": "not_affected",
      "justification": "vulnerable_code_not_present",
      "impact_statement": "The flaw is in the nghttpx proxy binary (the upstream fix touches only src/shrpx_*, zero lib/ code). This image ships only libnghttp2.so (nghttp2-libs), not the nghttpx binary (the nghttp2 package)."
    },
    {
      "vulnerability": { "name": "GHSA-cq8v-f236-94qc" },
      "timestamp": "2026-07-08T00:00:00Z",
      "products": [
        {
          "@id": "pkg:oci/mulewatch-verifier",
          "subcomponents": [
            { "@id": "pkg:cargo/rand" }
          ]
        }
      ],
      "status": "not_affected",
      "justification": "vulnerable_code_not_in_execute_path",
      "impact_statement": "The rand crate is embedded in librav1e (AV1 encoder) pulled by ffmpeg. The verifier runs only ffprobe for analysis, never the AV1 encoder, so the affected code path is never executed."
    }
  ]
