# Secrets & réglages de déploiement emule-indexer — COPIER en .env (gitignoré).
# Renseigne SEULEMENT ce qui concerne ta stack (cf. docs/runbooks/deployment.md, matrice de choix).
# Aucune orchestration ici : on choisit la stack avec `-f deploy/examples/<fichier>.yaml`.

# --- amuled (TOUTES stacks) : mot de passe EC, partagé avec le crawler via deploy/config/crawler/<mode>.yaml ---
AMULE_EC_PASSWORD=change-me

# --- gluetun (stacks A/B) ---
WIREGUARD_PRIVATE_KEY=change-me
# Nom du fournisseur tel qu'attendu par gluetun (protonvpn, pia, privatevpn, perfectprivacy, ...).
# Valeur ci-dessous = EXEMPLE, pas une recommandation — voir wiki gluetun pour la liste à jour :
# https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
VPN_SERVICE_PROVIDER=protonvpn
# Pays de sortie VPN, nom complet en anglais (Switzerland, France, Germany, ...). EXEMPLE :
SERVER_COUNTRIES=Switzerland
# B (High-ID via VPN) : passer "on" ET armer le bloc port_sync dans deploy/config/crawler/download.yaml
VPN_PORT_FORWARDING=off
# B : GID du groupe `docker` de l'hôte (getent group docker | cut -d: -f3) pour le docker-proxy
DOCKER_GID=

# --- High-ID statique (stack D) : DOIT égaler le port d'amuled (amule.conf Port=, défaut 4662) ---
LISTEN_PORT=4662
LISTEN_PORT_UDP=4672

# --- monitoring (profil monitoring) ---
GRAFANA_PWD=change-me
GRAFANA_PORT=3000

# --- divers ---
IMAGE_TAG=latest
# gVisor (durcissement noyau ; hôte Linux + runsc uniquement) — décommenter pour activer :
# CONTAINER_RUNTIME=runsc
